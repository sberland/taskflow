{
  "env": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit 2>&1)",
      "Bash(npm install typescript --save-dev 2>&1 | tail -3)",
      "Bash(npm run build 2>&1)",
      "Bash(trash node_modules && npm install 2>&1 | tail -5)",
      "Bash(npx prisma generate 2>&1 | tail -3)",
      "Bash(git checkout -b staging)",
      "Bash(git push -u origin staging)",
      "mcp__vercel__get_project",
      "mcp__vercel__list_deployments",
      "Bash(npm run:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/login)"
    ]
  }
}
