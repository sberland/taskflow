# Copier ce fichier en .env.local (dev) ou configurer dans Vercel (staging/prod)

# Base de données Neon — une URL par environnement
# Dev    : branche "dev" sur console.neon.tech
# Staging: branche "staging" sur console.neon.tech
# Prod   : branche "main" sur console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# NextAuth
# Dev    : http://localhost:3000
# Staging: https://staging-xxx.vercel.app
# Prod   : https://ton-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with: openssl rand -base64 32"
